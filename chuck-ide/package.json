{
  "name": "chuck-ide",
  "version": "0.1.0",
  "description": "L'Atelier 8-Bit — IDE for 6502",
  "type": "module",
  "scripts": {
    "ide:dev": "vite ide",
    "ide:build": "tsc && vite build --config ide/vite.config.js ide/",
    "ide:preview": "vite preview",
    "learn:dev": "vuepress dev learn",
    "learn:build": "vuepress build learn",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "yarn ide:build && yarn learn:build",
    "deploy": "wrangler pages deploy"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.8",
    "@vuepress/bundler-vite": "^2.0.0-rc.30",
    "@vuepress/theme-default": "^2.0.0-rc.130",
    "jsdom": "29.1.1",
    "sass-embedded": "^1.100.0",
    "typescript": "^6.0.3",
    "vite": "^8.0",
    "vitest": "^4.1",
    "vuepress": "^2.0.0-rc.30"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.16.0",
    "@codemirror/commands": "^6.3.3",
    "@codemirror/language": "^6.10.1",
    "@codemirror/legacy-modes": "^6.4.0",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.3",
    "@lezer/highlight": "^1.2.0"
  }
}
